import java.util.Scanner;

/**
 * Clase principal para probar ColaGenerica
 */
public class Main {

    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        // Inicialización de una cola genérica para almacenar cadenas de texto (Strings)
        ColaGenerica<String> cola = new ColaGenerica<>();

        // Inicialización de una cola genérica para números enteros (Integer)
         //ColaGenerica<Integer> cola = new ColaGenerica<>();

        // Inicialización de una cola genérica para objetos de tipo Cliente, etc...
        // ColaGenerica<Cliente> cola = new ColaGenerica<>();
        
        int opcion;

        do {
            System.out.println("\n========= MENÚ COLA GENÉRICA =========");
            System.out.println("1. Encolar elemento");
            System.out.println("2. Desencolar elemento");
            System.out.println("3. Mostrar cola");
            System.out.println("4. Mostrar frente");
            System.out.println("5. Mostrar final");
            System.out.println("6. Verificar si está vacía");
            System.out.println("7. Mostrar capacidad");
            System.out.println("8. Mostrar tamaño");
            System.out.println("9. Vaciar cola");
            System.out.println("0. Salir");
            System.out.print("Seleccione una opción: ");

            opcion = sc.nextInt();
            sc.nextLine(); 

            switch (opcion) {

                case 1:
                    System.out.print("Ingrese elemento a encolar: ");
                    String elemento = sc.nextLine();

                    cola.encolar(elemento);

                    System.out.println("Elemento encolado correctamente.");
                    break;

                case 2:
                    try {
                        String eliminado = cola.desencolar();
                        System.out.println("Elemento desencolado: " + eliminado);
                    } catch (IllegalStateException e) {
                        System.out.println(e.getMessage());
                    }
                    break;

                case 3:
                    System.out.println("Contenido de la cola:");
                    System.out.println(cola);
                    break;

                case 4:
                    try {
                        System.out.println("Elemento al frente: " + cola.frente());
                    } catch (IllegalStateException e) {
                        System.out.println(e.getMessage());
                    }
                    break;

                case 5:
                    try {
                        if (!cola.estaVacia()) {
                            System.out.println("Elemento al final: "
                                    + cola.ultimo());
                        } else {
                            System.out.println("La cola está vacía.");
                        }
                    } catch (Exception e) {
                        System.out.println(e.getMessage());
                    }
                    break;

                case 6:
                    if (cola.estaVacia()) {
                        System.out.println("La cola está vacía.");
                    } else {
                        System.out.println("La cola NO está vacía.");
                    }
                    break;

                case 7:
                    System.out.println("Capacidad actual: " + cola.capacidad());
                    break;

                case 8:
                    System.out.println("Tamaño actual: " + cola.tamaño());
                    break;

                case 9:
                    cola.vaciar();
                    System.out.println("La cola fue vaciada.");
                    break;

                case 0:
                    System.out.println("Saliendo del programa...");
                    break;

                default:
                    System.out.println("Opción inválida.");
            }

        } while (opcion != 0);

        sc.close();
    }

}
